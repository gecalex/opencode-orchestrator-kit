{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "file://.opencode/dist/index.js"
  ],
  "agent": {
    "orchestrator": {
      "description": "Главный оркестратор проекта",
      "mode": "primary"
    },
    "planning-task-analyzer": {
      "description": "Анализ и классификация задач, назначение агентов",
      "mode": "subagent"
    },
    "tdd-coordinator": {
      "description": "Координация TDD workflow по языкам",
      "mode": "subagent"
    },
    "constitution-agent": {
      "description": "Создание конституции проекта",
      "mode": "subagent"
    },
    "specify-agent": {
      "description": "Создание спецификаций модулей",
      "mode": "subagent"
    },
    "plan-agent": {
      "description": "Создание ОБЩЕГО плана проекта",
      "mode": "subagent"
    },
    "tasks-agent": {
      "description": "Разбивка плана на задачи",
      "mode": "subagent"
    },
    "specification-analyst": {
      "description": "Анализ противоречий и пробелов в спецификациях",
      "mode": "subagent"
    },
    "project-initializer": {
      "description": "Инициализация проекта",
      "mode": "subagent"
    },
    "python-developer": {
      "description": "Python backend разработка с TDD",
      "mode": "subagent"
    },
    "go-developer": {
      "description": "Go backend разработка с TDD",
      "mode": "subagent"
    },
    "react-developer": {
      "description": "React frontend разработка с TDD",
      "mode": "subagent"
    },
    "python-specialist": {
      "description": "Python тестирование (pytest, unittest)",
      "mode": "subagent"
    },
    "go-specialist": {
      "description": "Go тестирование (testing, testify)",
      "mode": "subagent"
    },
    "ts-specialist": {
      "description": "TypeScript/React тестирование (Jest, RTL)",
      "mode": "subagent"
    }
  },
  "mcp": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/home/alex/MyProjects/opencode_orc_kit"],
      "enabled": true
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "enabled": true
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "$GITHUB_TOKEN"
      },
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "searxng": {
      "command": "docker",
      "args": ["run", "-d", "--rm", "-p", "8080:8080", "-e", "SEARXNG_BASE_URL=http://localhost:8080/", "searxng/searxng"],
      "enabled": false
    },
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "enabled": false
    }
  }
}
